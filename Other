-- Other.lua
return function(Win, hub)
    local OtherTab = hub.HomeOtherTab

    -- ShiftLock
    OtherTab:Divider()
    OtherTab:Toggle({
        Title = "ShiftLock",
        Value = false,
        Flag = "ShiftLock",
        Callback = function(v)
            if v then
                loadstring(game:HttpGet("https://raw.githubusercontent.com/Neosq/ShiftLock/refs/heads/main/ShiftLock.txt"))()
            else
                _G.ShiftLockLoaded = nil
                if hub.CoreGui:FindFirstChild("ShiftlockGui") then hub.CoreGui.ShiftlockGui:Destroy() end
                if hub.LocalPlayer.PlayerGui:FindFirstChild("ShiftlockGui") then hub.LocalPlayer.PlayerGui.ShiftlockGui:Destroy() end
            end
        end
    })

    -- TpTool
    OtherTab:Divider()
    OtherTab:Toggle({
        Title = "TpTool",
        Value = false,
        Flag = "TpTool",
        Callback = function(v)
            if v then
                local tool = Instance.new("Tool")
                tool.Name = "TpTool"
                tool.RequiresHandle = false
                tool.Parent = hub.LocalPlayer.Backpack
                tool.Activated:Connect(function()
                    local mouse = hub.LocalPlayer:GetMouse()
                    local char = hub.LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") and mouse.Hit then
                        char.HumanoidRootPart.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0,3,0))
                    end
                end)
                if not game:GetService("StarterGui"):GetCoreGuiEnabled(Enum.CoreGuiType.Backpack) then
                    task.wait(0.5)
                    hub:Notify("Info", "Inventory not visible. Enable in Other tab", "info", 4)
                end
            else
                if hub.LocalPlayer.Backpack:FindFirstChild("TpTool") then hub.LocalPlayer.Backpack.TpTool:Destroy() end
                local char = hub.LocalPlayer.Character
                if char and char:FindFirstChild("TpTool") then char.TpTool:Destroy() end
            end
        end
    })
end
