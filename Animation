    -- Hydroxide
    IYTab:Divider()
    IYTab:Button({
        Title = "Load Hydroxide", Icon = "activity",
        Callback = function()
            local owner  = "Hosvile"
            local branch = "revision"
            local function webImport(file)
                return loadstring(
                    game:HttpGetAsync(("https://raw.githubusercontent.com/%s/MC-Hydroxide/%s/%s.lua"):format(owner, branch, file)),
                    file .. ".lua"
                )()
            end
            local ok, err = pcall(function()
                webImport("init")
                webImport("ui/main")
            end)
            if ok then
                hub:Notify("Loaded", "Hydroxide executed", "activity", 4)
            else
                hub:Notify("Error", "Hydroxide failed: " .. tostring(err), "x", 6)
            end
        end
    })

    PlayerTab2:Button({
        Title = "Load Hitbox Expander", Icon = "target",
        Callback = function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Vcsk/RobloxScripts/main/HitboxExpander.lua"))()
            hub:Notify("Loaded", "Hitbox Expander executed", "target", 4)
        end
    })

    PlayerTab2:Button({
        Title = "Load Fling GUI", Icon = "move-3d",
        Callback = function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/0Ben1/fe./main/Fling%20GUI"))()
            hub:Notify("Loaded", "Fling GUI executed", "move-3d", 4)
        end
    })

    PlayerTab2:Paragraph({
        Title = "Note",
        Desc = "External scripts from GitHub.\nUse at your own risk."
    })
end
