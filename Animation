    local currentBundle    = "Rthro"
    local animationsEnabled = false

    local function refreshAnims(char)
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if hum then for _, t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop(0) end end
    end

    local function applyAnimations(char)
        local hum     = char:WaitForChild("Humanoid", 5)
        local animate = char:WaitForChild("Animate", 5)
        if not hum or not animate then return end

        local animData = hub.HybridMode and {
            idle=hub.H_Idle, walk=hub.H_Walk, run=hub.H_Run,
            jump=hub.H_Jump, fall=hub.H_Fall, climb=hub.H_Climb, swim=hub.H_Swim
        } or (AnimationPacks[currentBundle] or AnimationPacks["Rthro"])

        for animName, id in pairs(animData) do
            if id and id ~= "" then
                local container = animate:FindFirstChild(animName) or animate:FindFirstChild(animName:gsub("^%l", string.upper))
                if container then
                    for _, obj in pairs(container:GetChildren()) do
                        if obj:IsA("Animation") then obj.AnimationId = "rbxassetid://" .. id end
                    end
                end
            end
        end

        animate.Disabled = true
        refreshAnims(char)
        task.wait(0.08)
        animate.Disabled = false
        hum:ChangeState(Enum.HumanoidStateType.Landed)
    end

    local function tryApplyAnims()
        if animationsEnabled and hub.LocalPlayer.Character then
            applyAnimations(hub.LocalPlayer.Character)
        end
    end

    local function onCharacterAdded(char)
        task.delay(0.4, function()
            if animationsEnabled then applyAnimations(char) end
        end)
        char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") and animationsEnabled then
                task.delay(0.06, function() if char.Parent then refreshAnims(char) end end)
            end
        end)
        char.ChildRemoved:Connect(function(child)
            if child:IsA("Tool") and animationsEnabled then
                task.delay(0.06, function() if char.Parent then refreshAnims(char) end end)
            end
        end)
    end

    if hub.LocalPlayer.Character then task.spawn(onCharacterAdded, hub.LocalPlayer.Character) end
    hub.LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

    -- Standard
    StandardTab:Dropdown({
        Title = "Select Bundle", Values = animList, Multi = false,
        Value = "Rthro", Flag = "SelectedAnimFlag",
        Callback = function(v) currentBundle = v; tryApplyAnims() end
    })
    StandardTab:Toggle({
        Title = "Enable Animations", Value = false, Flag = "AnimToggle",
        Callback = function(v)
            animationsEnabled = v
            hub.HybridMode = false
            tryApplyAnims()
        end
    })

    -- Hybrid
    local hybridSlots = {"Idle","Walk","Run","Jump","Fall","Climb","Swim"}
    for _, slot in ipairs(hybridSlots) do
        HybridTab:Dropdown({
            Title = slot, Values = animList, Multi = false,
            Value = hub["H_"..slot] or "Rthro", Flag = "Hybrid"..slot,
            Callback = function(v)
                hub["H_"..slot] = v
                if hub.HybridMode then tryApplyAnims() end
            end
        })
    end
    HybridTab:Toggle({
        Title = "Use Hybrid Mode", Value = false, Flag = "HybridEnabled",
        Callback = function(v)
            hub.HybridMode = v
            animationsEnabled = v
            tryApplyAnims()
        end
    })

    -- Build Manager
    local HttpService = hub.HttpService
    local buildFile   = "JustAHub/builds.json"
    local myBuilds    = {}
    local buildDropdown

    local function loadBuildsFromFile()
        if isfile and isfile(buildFile) then
            local ok, data = pcall(function() return HttpService:JSONDecode(readfile(buildFile)) end)
            if ok and type(data) == "table" then myBuilds = data end
        end
    end
    local function saveBuildsToFile()
        if writefile then writefile(buildFile, HttpService:JSONEncode(myBuilds)) end
    end
    local function refreshBuildList()
        local names = {}
        for name in pairs(myBuilds) do table.insert(names, name) end
        table.sort(names)
        if buildDropdown then buildDropdown:Refresh(names) end
    end

    task.spawn(function() loadBuildsFromFile(); task.delay(0.5, refreshBuildList) end)

    local buildNameInput = ""
    BuildMgrTab:Input({ Title = "Build Name", Placeholder = "Enter name...", Callback = function(v) buildNameInput = v end })
    BuildMgrTab:Button({
        Title = "Save Build", Icon = "save",
        Callback = function()
            if buildNameInput == "" then hub:Notify("Error", "Enter a build name first", "alert-circle") return end
            myBuilds[buildNameInput] = {
                Idle=hub.H_Idle, Walk=hub.H_Walk, Run=hub.H_Run,
                Jump=hub.H_Jump, Fall=hub.H_Fall, Climb=hub.H_Climb, Swim=hub.H_Swim
            }
            saveBuildsToFile(); refreshBuildList()
            hub:Notify("Success", "Build '"..buildNameInput.."' saved!", "save")
            buildNameInput = ""
        end
    })

    buildDropdown = BuildMgrTab:Dropdown({
        Title = "Saved Builds", Values = {}, Multi = false, Value = "", Flag = "SelectedBuild",
        Callback = function(selected)
            if myBuilds[selected] then
                local b = myBuilds[selected]
                hub.H_Idle=b.Idle; hub.H_Walk=b.Walk; hub.H_Run=b.Run
                hub.H_Jump=b.Jump; hub.H_Fall=b.Fall; hub.H_Climb=b.Climb; hub.H_Swim=b.Swim
                hub.HybridMode = true; animationsEnabled = true
                tryApplyAnims()
                hub:Notify("Loaded", "Build '"..selected.."' loaded", "check")
            end
        end
    })

    BuildMgrTab:Button({
        Title = "Copy Build Code", Icon = "copy",
        Callback = function()
            local parts = {}
            for _, t in ipairs(hybridSlots) do
                table.insert(parts, tostring(table.find(animList, hub["H_"..t]) or 23))
            end
            local code = table.concat(parts, "-")
            setclipboard(code)
            hub:Notify("Copied", "Build code: "..code, "clipboard")
        end
    })

    BuildMgrTab:Input({
        Title = "Paste Sharing Code", Placeholder = "Example: 5-12-8-15-3-27-19",
        Callback = function(code)
            if not code or code == "" then return end
            local nums = string.split(code, "-")
            if #nums ~= 7 then hub:Notify("Error", "Code must have 7 numbers", "x") return end
            for i, numStr in ipairs(nums) do
                local idx = tonumber(numStr)
                if idx and idx >= 1 and idx <= #animList then
                    hub["H_"..hybridSlots[i]] = animList[idx]
                end
            end
            hub.HybridMode = true; animationsEnabled = true
            tryApplyAnims()
            hub:Notify("Success", "Code applied – Hybrid mode enabled", "check")
        end
    })

